# MongoDB Connection String
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/carbonchain?retryWrites=true&w=majority

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_key_here_min_32_chars_recommended

# Gemini API Key for AI optimization
GEMINI_API_KEY=your_gemini_api_key_here

# Node Environment
NODE_ENV=production

# Server Port (Vercel assigns automatically)
PORT=3000

# Frontend URL
FRONTEND_URL=https://your-domain.vercel.app

# Python Backend URL (change if hosted on different platform)
PYTHON_BACKEND_URL=https://python-backend.railway.app

# Node Backend URL (for Python to callback)
NODE_BACKEND_URL=https://your-domain.vercel.app

# Allowed CORS Origins (comma-separated)
ALLOWED_ORIGINS=https://your-domain.vercel.app,https://www.your-domain.vercel.app

# API keys and secrets
DATABASE_NAME=carbonchain_pro
LOG_LEVEL=info
